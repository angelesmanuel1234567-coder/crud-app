<!DOCTYPE html>
<html>
<head>
    <title>Productos</title>

    <!-- 🔥 CLAVE PARA RESPONSIVE -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
    body {
    font-family: 'Segoe UI', sans-serif;
    color: #e2e8f0;
    padding: 20px;

    background: linear-gradient(rgba(15,23,42,0.92), rgba(15,23,42,0.92)),
                url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da');

    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
}
    h1 {
        text-align: center;
        color: #38bdf8;
        font-size: 30px;
        margin-bottom: 20px;
    }

    

   input {
    padding: 10px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(15,23,42,0.7);
    color: #e2e8f0;
}

    button {
        padding: 10px 15px;
        border: none;
        border-radius: 8px;
        background: #38bdf8;
        color: #0f172a;
        font-weight: bold;
        cursor: pointer;
    }

    form {
    background: rgba(30, 41, 59, 0.55);
    backdrop-filter: blur(10px);
    padding: 20px;
    max-width: 650px;
    margin: auto;
    border-radius: 12px;
    display: flex;
    gap: 10px;
    border: 1px solid rgba(255,255,255,0.1);
}

table {
    width: 100%;
    margin-top: 25px;
    background: rgba(30, 41, 59, 0.55);
    backdrop-filter: blur(10px);
    border-collapse: collapse;
    border-radius: 12px;
    overflow: hidden;
}

    th {
        background: #0f172a;
        color: #38bdf8;
        padding: 12px;
    }

    td {
        padding: 12px;
        text-align: center;
        border-bottom: 1px solid #334155;
    }

    a {
        padding: 6px 10px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 12px;
        margin: 2px;
        display: inline-block;
        font-weight: bold;
    }

    .edit { background: #facc15; color: #0f172a; }
    .delete { background: #ef4444; color: white; }

    @media (max-width: 768px) {

    body {
        padding: 10px;
        background-attachment: scroll; /* 🔥 mejora rendimiento móvil */
    }

    h1 {
        font-size: 22px;
    }

    form {
        flex-direction: column;
        max-width: 100%;
        padding: 15px;
    }

    input, button {
        width: 100%;
        font-size: 14px;
    }

    /* tarjetas más compactas */
    tr {
        background: rgba(30, 41, 59, 0.6);
        backdrop-filter: blur(6px);
        margin-bottom: 12px;
        border-radius: 10px;
        padding: 10px;
    }

    td {
        font-size: 13px;
        padding: 8px;
    }

    td::before {
        font-size: 12px;
    }
}
</style>
</head>

<body>

<h1>📦 Productos</h1>

<form action="<%= editar ? '/productos/edit/' + editar.id_producto : '/productos' %>" method="POST">

    <input name="descripcion" placeholder="Descripción"
        value="<%= editar ? editar.descripcion : '' %>" required>

    <input name="precio" placeholder="Precio"
        value="<%= editar ? editar.precio : '' %>" required>

    <input name="stock" placeholder="Stock"
        value="<%= editar ? editar.stock : '' %>" required>

    <button>
        <%= editar ? 'Actualizar' : 'Guardar' %>
    </button>

</form>

<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
    <% productos.forEach(p => { %>
        <tr>
            <td data-label="ID"><%= p.id_producto %></td>
            <td data-label="Descripción"><%= p.descripcion %></td>
            <td data-label="Precio"><%= p.precio %></td>
            <td data-label="Stock"><%= p.stock %></td>
            <td data-label="Acciones">
                <a class="edit" href="/productos/edit/<%= p.id_producto %>">Editar</a>
                <a class="delete" href="/productos/delete/<%= p.id_producto %>">Eliminar</a>
            </td>
        </tr>
    <% }) %>
    </tbody>
</table>

</body>
</html>
