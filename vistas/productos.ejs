<!DOCTYPE html>
<html>
<head>
<title>Productos</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
:root {
    --bg-dark: rgba(15,23,42,0.85);
    --glass: rgba(255,255,255,0.05);
    --border: rgba(255,255,255,0.1);
    --primary: #38bdf8;
    --text: #e2e8f0;
}

body {
    font-family: 'Segoe UI', sans-serif;
    color: var(--text);
    padding: 20px;

    background: linear-gradient(var(--bg-dark), var(--bg-dark)),
    url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da');

    background-size: cover;
    background-position: center;
    background-attachment: fixed;
}

/* TITULO */
h1 {
    text-align: center;
    color: var(--primary);
    font-size: 28px;
    margin-bottom: 25px;
}

/* FORM */
form {
    background: var(--glass);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    padding: 18px;
    max-width: 650px;
    margin: auto;
    border-radius: 14px;
    display: flex;
    gap: 10px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
}

input {
    flex: 1;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: rgba(15,23,42,0.6);
    color: var(--text);
}

input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 6px var(--primary);
}

/* BOTON */
button {
    padding: 10px 15px;
    border-radius: 8px;
    border: none;
    background: var(--primary);
    color: #0f172a;
    font-weight: bold;
    cursor: pointer;
    transition: 0.2s;
}

button:hover {
    transform: scale(1.05);
    background: #0ea5e9;
}

/* TABLA */
table {
    width: 100%;
    margin-top: 25px;
    border-collapse: collapse;
}

thead {
    background: rgba(0,0,0,0.3);
}

th {
    padding: 12px;
    color: var(--primary);
    font-size: 13px;
}

tbody tr {
    background: var(--glass);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    transition: 0.2s;
}

tbody tr:hover {
    background: rgba(255,255,255,0.08);
}

td {
    padding: 12px;
    text-align: center;
}

/* BOTONES ACCION */
a {
    padding: 6px 10px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 12px;
    margin: 2px;
    font-weight: bold;
}

.edit {
    background: rgba(250,204,21,0.8);
    color: #000;
}

.delete {
    background: rgba(239,68,68,0.8);
    color: white;
}

/* 📱 RESPONSIVE PRO */
@media (max-width: 768px) {

    body {
        padding: 10px;
        background-attachment: scroll;
    }

    form {
        flex-direction: column;
    }

    input, button {
        width: 100%;
    }

    table, thead, tbody, tr, td {
        display: block;
        width: 100%;
    }

    thead {
        display: none;
    }

    tr {
        margin-bottom: 15px;
        border-radius: 12px;
        padding: 10px;
        background: var(--glass);
        backdrop-filter: blur(8px);
    }

    td {
        text-align: left;
        padding: 8px;
        border-bottom: 1px solid var(--border);
    }

    td::before {
        content: attr(data-label);
        display: block;
        font-weight: bold;
        color: var(--primary);
        margin-bottom: 4px;
        font-size: 12px;
    }
}
</style>
</head>

<body>

<h1>📦 Productos</h1>

<form action="<%= editar ? '/productos/edit/' + editar.id_producto : '/productos' %>" method="POST">
    <input name="descripcion" placeholder="Descripción" value="<%= editar ? editar.descripcion : '' %>" required>
    <input name="precio" placeholder="Precio" value="<%= editar ? editar.precio : '' %>" required>
    <input name="stock" placeholder="Stock" value="<%= editar ? editar.stock : '' %>" required>
    <button><%= editar ? 'Actualizar' : 'Guardar' %></button>
</form>

<table>
<thead>
<tr>
<th>ID</th>
<th>Descripción</th>
<th>Precio</th>
<th>Stock</th>
<th>Acciones</th>
</tr>
</thead>

<tbody>
<% productos.forEach(p => { %>
<tr>
<td data-label="ID"><%= p.id_producto %></td>
<td data-label="Descripción"><%= p.descripcion %></td>
<td data-label="Precio"><%= p.precio %></td>
<td data-label="Stock"><%= p.stock %></td>
<td data-label="Acciones">
<a class="edit" href="/productos/edit/<%= p.id_producto %>">Editar</a>
<a class="delete" href="/productos/delete/<%= p.id_producto %>">Eliminar</a>
</td>
</tr>
<% }) %>
</tbody>
</table>

</body>
</html>
